---
import { photo, images } from '../data';
---

<section class="cta" id="shop">
  <div class="cta-texture" aria-hidden="true">
    <img src={photo(images.laserLiverpool, 1600)} width="1600" height="900" loading="lazy" alt="" />
  </div>
  <div class="wrap cta-inner">
    <h2 class="reveal">Have something in mind?</h2>
    <p class="reveal" style="--reveal-delay: 90ms">
      Tell me what you want made. I will say honestly whether wood, steel, or
      laser is right for it, what it costs, and how long it takes.
    </p>
    <div class="cta-actions reveal" style="--reveal-delay: 170ms">
      <a href="mailto:dino@craftasaurusrex.com?subject=Commission" class="btn">
        Start a commission
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor"
          stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
      <span class="cta-note">The shop opens soon. Commissions are open now.</span>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: oklch(0.95 0.006 70);
    background: oklch(0.2 0.014 48);
    padding-block: clamp(3.25rem, 6.5vw, 5.5rem);
  }
  .cta-texture {
    position: absolute;
    inset: 0;
    z-index: -2;
    opacity: 0.24;
  }
  .cta-texture img { width: 100%; height: 100%; object-fit: cover; filter: saturate(0.7); }
  .cta::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(180deg, oklch(0.2 0.014 48 / 0.7), oklch(0.16 0.014 46 / 0.92)),
      radial-gradient(70% 80% at 80% 20%, var(--glow), transparent 60%);
  }

  .cta-inner {
    max-width: 44rem;
    text-align: center;
    margin-inline: auto;
  }
  .cta-inner h2 {
    font-size: clamp(2.3rem, 5.2vw, 4rem);
    margin: 0;
    color: oklch(0.98 0.005 75);
  }
  .cta-inner p {
    margin: 1.25rem auto 0;
    max-width: 46ch;
    font-size: 1.15rem;
    color: oklch(0.86 0.01 70);
  }
  .cta-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    margin-top: 2.25rem;
  }
  .cta-note {
    font-size: 0.9rem;
    color: oklch(0.78 0.012 68);
  }
</style>

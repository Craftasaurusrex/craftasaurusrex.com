---
import { photo, pieces, socials } from '../data';
const instagram = socials.find((s) => s.label === 'Instagram');
---

<section class="featured" id="work">
  <div class="wrap">
    <div class="featured-head">
      <h2 class="reveal">Recent pieces off the bench.</h2>
      <p class="reveal" style="--reveal-delay: 80ms">
        A few things made lately. The shop opens soon. Until then, commissions
        are open and every piece can be made to your size.
      </p>
    </div>

    <div class="bento">
      {
        pieces.map((p, i) => (
          <figure class={`piece piece--${p.span} reveal`} style={`--reveal-delay: ${i * 90}ms`}>
            <div class="piece-media">
              <img
                src={photo(p.img, 1000)}
                srcset={`${photo(p.img, 700)} 700w, ${photo(p.img, 1100)} 1100w`}
                sizes="(max-width: 780px) 92vw, 45vw"
                width="700"
                height="700"
                loading="lazy"
                alt={p.alt}
              />
            </div>
            <figcaption>
              <span class="piece-title">{p.title}</span>
              <span class="piece-meta" set:html={p.meta}></span>
            </figcaption>
          </figure>
        ))
      }
    </div>

    <a class="featured-ig reveal" href={instagram.href} target="_blank" rel="noopener"
      style="--reveal-delay: 330ms">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor"
        stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="2" width="20" height="20" rx="5"></rect>
        <circle cx="12" cy="12" r="4"></circle>
        <circle cx="17.5" cy="6.5" r="1.1" fill="currentColor" stroke="none"></circle>
      </svg>
      Keep up with my work on Instagram
    </a>
  </div>
</section>

<style>
  .featured {
    padding-block: clamp(3rem, 6.5vw, 5.5rem);
  }
  .featured-head {
    display: flex;
    flex-wrap: wrap;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem 2rem;
    max-width: 62rem;
    margin-bottom: clamp(2.25rem, 4.5vw, 3.5rem);
  }
  .featured-head h2 {
    font-size: clamp(2rem, 4.4vw, 3.4rem);
    margin: 0;
    flex: 1 1 18ch;
  }
  .featured-head p {
    margin: 0;
    color: var(--ink-soft);
    max-width: 38ch;
    font-size: 1.02rem;
  }

  .bento {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: clamp(1rem, 2vw, 1.75rem);
    align-items: start;
  }
  .piece { margin: 0; }
  .piece:first-child { align-self: center; }
  .piece--lead { grid-column: span 3; grid-row: span 2; }
  .piece--tall { grid-column: span 3; }
  .piece--wide { grid-column: span 3; }

  .piece-media {
    position: relative;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface-2);
    box-shadow: 0 18px 40px -30px oklch(0.235 0.012 55 / 0.5);
  }
  .piece-media::after {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow: inset 0 0 0 1px var(--hairline);
    border-radius: var(--radius);
  }
  .piece-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s var(--ease-out);
  }
  .piece--lead .piece-media img { aspect-ratio: 4 / 5; }
  .piece--tall .piece-media img { aspect-ratio: 16 / 11; }
  .piece--wide .piece-media img { aspect-ratio: 16 / 11; }
  .piece:nth-child(2) .piece-media img { object-position: 0% 14%; }
  @media (hover: hover) and (pointer: fine) {
    .piece:hover .piece-media img { transform: scale(1.03); }
  }

  figcaption {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding-top: 0.85rem;
  }
  .piece-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.12rem;
    letter-spacing: -0.01em;
  }
  .piece-meta {
    color: var(--ink-soft);
    font-size: 0.9rem;
  }

  .featured-ig {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    margin-top: clamp(2.25rem, 4vw, 3.5rem);
    color: var(--ink);
    text-decoration: none;
    font-weight: 600;
    border-bottom: 1px solid var(--hairline);
    padding-bottom: 0.25rem;
    transition: color 0.2s var(--ease-out), border-color 0.2s var(--ease-out);
  }
  .featured-ig:hover { color: var(--ember); border-color: var(--ember); }

  @media (max-width: 780px) {
    .bento { grid-template-columns: 1fr 1fr; }
    .piece--lead,
    .piece--tall,
    .piece--wide { grid-column: span 1; grid-row: auto; }
    .piece--lead { grid-column: span 2; }
    .piece--lead .piece-media img { aspect-ratio: 16 / 11; }
  }
  @media (max-width: 460px) {
    .bento { grid-template-columns: 1fr; }
    .piece--lead { grid-column: span 1; }
  }
</style>

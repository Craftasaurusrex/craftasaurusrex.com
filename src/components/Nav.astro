---
import { nav } from '../data';
---

<header class="site-head">
  <div class="wrap head-inner">
    <a href="#top" class="brand" aria-label="Craftasaurus, home">
      <span class="brand-mark" aria-hidden="true"></span>
      <span class="brand-word">Craftasaurus</span>
    </a>

    <nav class="head-nav" aria-label="Primary">
      <ul>
        {nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      </ul>
    </nav>

    <div class="head-actions">
      <button
        class="icon-btn"
        data-theme-toggle
        type="button"
        aria-pressed="false"
        aria-label="Toggle dark mode"
        title="Toggle dark mode">
        <svg class="i-sun" viewBox="0 0 24 24" width="19" height="19" fill="none"
          stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
        </svg>
        <svg class="i-moon" viewBox="0 0 24 24" width="19" height="19" fill="none"
          stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
        </svg>
      </button>

      <a href="#shop" class="btn head-cta">Commission</a>

      <button
        class="icon-btn menu-btn"
        type="button"
        aria-expanded="false"
        aria-controls="mobile-nav"
        aria-label="Open menu">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor"
          stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18"></path>
        </svg>
      </button>
    </div>
  </div>

  <div class="mobile-nav" id="mobile-nav" hidden>
    <ul class="wrap">
      {nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
      <li><a href="#shop" class="mobile-cta">Commission a piece</a></li>
    </ul>
  </div>
</header>

<style>
  .site-head {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklch, var(--surface) 86%, transparent);
    backdrop-filter: saturate(1.2) blur(10px);
    border-bottom: 1px solid transparent;
    transition: border-color 0.3s var(--ease-out), background-color 0.3s var(--ease-out);
  }
  .site-head[data-stuck] {
    border-bottom-color: var(--hairline);
  }
  @supports not (backdrop-filter: blur(1px)) {
    .site-head { background: var(--surface); }
  }

  .head-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 68px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--ink);
    text-decoration: none;
    margin-right: auto;
  }
  .brand-mark {
    flex: none;
    width: 30px;
    height: 30px;
    background: var(--ember);
    -webkit-mask: url('/mark.png') center / contain no-repeat;
    mask: url('/mark.png') center / contain no-repeat;
    transition: transform 0.4s var(--ease-out), background-color 0.2s var(--ease-out);
  }
  .brand:hover .brand-mark { transform: scale(1.08); background: var(--ember-hot); }
  @media (prefers-reduced-motion: reduce) {
    .brand-mark { transition: background-color 0.2s var(--ease-out); }
    .brand:hover .brand-mark { transform: none; }
  }
  .brand-word {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.28rem;
    letter-spacing: -0.03em;
  }

  .head-nav ul {
    display: flex;
    gap: 1.9rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .head-nav a {
    color: var(--ink-soft);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.96rem;
    position: relative;
    padding-block: 0.4rem;
    transition: color 0.2s var(--ease-out);
  }
  .head-nav a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0.1rem;
    width: 100%;
    height: 1.5px;
    background: var(--ember);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s var(--ease-out);
  }
  .head-nav a:hover { color: var(--ink); }
  .head-nav a:hover::after { transform: scaleX(1); }

  .head-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .icon-btn {
    display: inline-grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius);
    border: 1px solid var(--hairline);
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    transition: background-color 0.2s var(--ease-out), transform 0.16s var(--ease-out);
  }
  .icon-btn:hover { background: var(--surface-2); }
  .icon-btn:active { transform: scale(0.94); }
  .icon-btn svg { grid-area: 1 / 1; }

  .i-moon { display: none; }
  :root[data-theme='dark'] .i-sun { display: none; }
  :root[data-theme='dark'] .i-moon { display: block; }

  .menu-btn { display: none; }
  .head-cta { padding: 0.7rem 1.2rem; font-size: 0.93rem; }

  .mobile-nav { display: none; }
  .mobile-nav ul {
    list-style: none;
    margin: 0;
    padding: 1rem 0 1.5rem;
    display: grid;
    gap: 0.25rem;
  }
  .mobile-nav a {
    display: block;
    padding: 0.85rem 0;
    color: var(--ink);
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.5rem;
    letter-spacing: -0.02em;
    border-bottom: 1px solid var(--hairline);
  }
  .mobile-nav .mobile-cta { color: var(--ember); border-bottom: none; }

  @media (max-width: 820px) {
    .head-nav,
    .head-cta { display: none; }
    .menu-btn { display: inline-grid; }
    .mobile-nav { display: block; border-top: 1px solid var(--hairline); }
    .mobile-nav[hidden] { display: none; }
  }
</style>

<script>
  // Sticky hairline once the page scrolls past the header.
  const head = document.querySelector('.site-head');
  if (head) {
    const sentinel = document.createElement('div');
    sentinel.style.cssText = 'position:absolute;top:0;height:1px;width:1px;';
    document.body.prepend(sentinel);
    new IntersectionObserver(
      ([e]) => head.toggleAttribute('data-stuck', !e.isIntersecting),
      { threshold: 0 },
    ).observe(sentinel);
  }

  // Mobile menu
  const menuBtn = document.querySelector('.menu-btn');
  const mobileNav = document.getElementById('mobile-nav');
  if (menuBtn && mobileNav) {
    const setOpen = (open: boolean) => {
      menuBtn.setAttribute('aria-expanded', String(open));
      mobileNav.toggleAttribute('hidden', !open);
      menuBtn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    };
    menuBtn.addEventListener('click', () =>
      setOpen(menuBtn.getAttribute('aria-expanded') !== 'true'),
    );
    mobileNav.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => setOpen(false)),
    );
  }
</script>

---
import { nav, socials } from '../data';
const year = new Date().getFullYear();
---

<footer class="site-foot">
  <div class="wrap foot-top">
    <div class="foot-brand">
      <a href="#top" class="brand" aria-label="Craftasaurus, home">
        <span class="brand-mark" aria-hidden="true"></span>
        <span>Craftasaurus</span>
      </a>
      <p>Handmade in wood, steel, and fire. Built to be kept.</p>
    </div>

    <nav class="foot-nav" aria-label="Footer">
      <ul>
        {nav.map((item) => <li><a href={item.href}>{item.label}</a></li>)}
        <li><a href="#maker">The maker</a></li>
      </ul>
    </nav>

    <div class="foot-contact">
      <a class="arrow-link" href="mailto:dino@craftasaurusrex.com">
        dino@craftasaurusrex.com
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor"
          stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14M13 6l6 6-6 6"></path>
        </svg>
      </a>
      <p>Commissions open. Reply within two working days.</p>
      <ul class="foot-social">
        {socials.map((s) => (
          <li>
            <a href={s.href} aria-label={s.label} target="_blank" rel="noopener">
              {s.label === 'Instagram' ? (
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor"
                  stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="2" width="20" height="20" rx="5"></rect>
                  <circle cx="12" cy="12" r="4"></circle>
                  <circle cx="17.5" cy="6.5" r="1.1" fill="currentColor" stroke="none"></circle>
                </svg>
              ) : (
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor"
                  stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="2" y="5" width="20" height="14" rx="4"></rect>
                  <path d="M10 9l5 3-5 3z" fill="currentColor" stroke="none"></path>
                </svg>
              )}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>

  <div class="wrap foot-bottom">
    <span>&copy; {year} Craftasaurus</span>
    <span>Made by hand, one at a time.</span>
  </div>
</footer>

<style>
  .site-foot {
    border-top: 1px solid var(--hairline);
    padding-block: clamp(2.5rem, 5vw, 3.75rem) 2rem;
  }
  .foot-top {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1.2fr;
    gap: 2.5rem;
    align-items: start;
  }
  .foot-brand .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--ink);
    text-decoration: none;
  }
  .foot-brand .brand-mark {
    flex: none;
    width: 24px;
    height: 24px;
    background: var(--ember);
    -webkit-mask: url('/mark.png') center / contain no-repeat;
    mask: url('/mark.png') center / contain no-repeat;
  }
  .foot-brand .brand span {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: -0.03em;
  }
  .foot-brand p {
    margin: 0.9rem 0 0;
    color: var(--ink-soft);
    max-width: 28ch;
  }

  .foot-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.7rem;
  }
  .foot-nav a {
    color: var(--ink-soft);
    text-decoration: none;
    transition: color 0.2s var(--ease-out);
  }
  .foot-nav a:hover { color: var(--ember); }

  .foot-contact p {
    margin: 0.8rem 0 0;
    color: var(--ink-soft);
    font-size: 0.92rem;
    max-width: 26ch;
  }
  .foot-social {
    list-style: none;
    margin: 1.1rem 0 0;
    padding: 0;
    display: flex;
    gap: 0.6rem;
  }
  .foot-social a {
    display: inline-grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius);
    border: 1px solid var(--hairline);
    color: var(--ink);
    transition: color 0.2s var(--ease-out), border-color 0.2s var(--ease-out);
  }
  .foot-social a:hover { color: var(--ember); border-color: var(--ember); }

  .foot-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: clamp(2.5rem, 5vw, 4rem);
    padding-top: 1.5rem;
    border-top: 1px solid var(--hairline);
    color: var(--ink-soft);
    font-size: 0.85rem;
  }

  @media (max-width: 720px) {
    .foot-top { grid-template-columns: 1fr; gap: 2rem; }
    .foot-bottom { flex-direction: column; gap: 0.4rem; }
  }
</style>
